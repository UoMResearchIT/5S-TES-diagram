model {
  extend egress {
    // Components
    egress_ui = component 'Egress UI' 'UI for approving or rejecting data exfiltration'
    egress_api = component 'Egress API' 'API for supporting egress'
    keycloak = component 'Keycloak'

    // Relationships
    data_owner -> egress_ui 'Views / Approves'
    egress_ui -> tre.tre_ui ''
  }
}

views {
  view of egress {
    title 'Egress Service'
    include *
  }
}